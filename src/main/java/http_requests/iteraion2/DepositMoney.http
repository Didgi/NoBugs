# Positive test: user can deposit 2000 money into his account
### Precondition step: get auth token by admin
POST http://localhost:4111/api/v1/auth/login
Content-Type: application/json

{
  "username": "admin",
  "password": "admin"
}
### Precondition step: admin creates a new user
POST http://localhost:4111/api/v1/admin/users
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

{
  "username": "user1",
  "password": "Password1!",
  "role": "USER"
}
### Precondition step: get auth token by user
POST http://localhost:4111/api/v1/auth/login
Content-Type: application/json

{
"username": "user1",
"password": "Password1!"
}

### Precondition step: Authorized user creates an account
POST http://localhost:4111/api/v1/accounts
Content-Type: application/json
Authorization: Basic a2F0ZTE5OTgxOmthdGUxOTk4MQ==

### Main step 1: deposit 2000 money
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 1,
  "balance": 2000
}

### Main step 2: check updated balance (amount) on user account
GET /api/v1/accounts/1/transactions
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

# Positive test: user can deposit money into his account twice and more times with common amount more 5000
### Precondition: contains previous steps
### Main step 1: deposit 4999 money
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 1,
  "balance": 4999
}

### Main step 2: deposit 5000 money
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 1,
  "balance": 5000.0
}

### Main step 3: check updated balance (amount) on user account
GET /api/v1/accounts/1/transactions
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

# Positive test: user can deposit money into his second and more accounts
### Precondition step: Authorized user creates an account
POST http://localhost:4111/api/v1/accounts
Content-Type: application/json
Authorization: Basic a2F0ZTE5OTgxOmthdGUxOTk4MQ==

### Precondition step: Authorized user creates one more account
POST http://localhost:4111/api/v1/accounts
Content-Type: application/json
Authorization: Basic a2F0ZTE5OTgxOmthdGUxOTk4MQ==

### Main step 1: deposit 0.01 money into his first account
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 1,
  "balance": 0.01
}

### Main step 2: deposit 5000 money into his second account
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 2,
  "balance": 5000
}

### Main step 3: check updated balance (amount) on first user account
GET /api/v1/accounts/1/transactions
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

### Main step 4: check updated balance (amount) on second user account
GET /api/v1/accounts/2/transactions
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

# Negative test: user cannot deposit 0 money into his account
### Main step 1: deposit 0 money
POST http://localhost:4111/api/v1/accounts/deposit
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=
{
  "id": 1,
  "balance": 0
}

### Main step 2: check unupdated balance (amount) on user account
GET /api/v1/accounts/1/transactions
Content-Type: application/json
Authorization: Basic YWRtaW46YWRtaW4=

